{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "static/types/modules.d.ts",
    "components/websocket/base/frontend/ws.ts",
    "components/websocket/common/frontend/heartbeat_orbit.ts",
    "components/websocket/common/frontend/heartbeat_payload_worker.ts",
    "components/websocket/ecc/frontend/ws.ts",
    "components/websocket/heartbeat/frontend/ws.ts",
    "components/websocket/heartbeat_earth/frontend/ws.ts",
    "components/websocket/heartbeat_earth_moon/frontend/ws.ts",
    "components/websocket/toast/frontend/ws.ts",
    "pages/playground/static/ws-status.ts",
    "pages/ble/static/app.ts",
    "pages/youtube/static/app.ts",
    "static/js/ws-status.ts"
  ],
  "exclude": [
    "pages/excalibur/**",
    "vendor/**",
    "**/__pycache__/**"
  ]
}
