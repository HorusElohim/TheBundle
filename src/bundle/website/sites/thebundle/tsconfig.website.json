{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "../../static/types/modules.d.ts",
    "../../builtin/runtime/**/*.ts",
    "../../builtin/component/**/*.ts",
    "pages/playground/static/ws-status.ts",
    "pages/ble/static/app.ts",
    "pages/youtube/static/app.ts",
    "../../static/js/ws-status.ts"
  ],
  "exclude": [
    "pages/excalidraw/**",
    "../../vendor/**",
    "**/__pycache__/**"
  ]
}
