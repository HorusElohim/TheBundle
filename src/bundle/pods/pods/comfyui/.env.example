# Optional: needed only for gated/private HF repos
HF_TOKEN=

# Build arg (pin this for reproducibility)
COMFYUI_VERSION=master

# ComfyUI VRAM mode: auto | high | normal | low | no
VRAM=high

# 1 = install custom nodes on startup (first run), 0 = skip
INSTALL_CUSTOM_NODES=1

# 1 = git pull custom node repos on startup, 0 = keep pinned local copies
CUSTOM_NODES_UPDATE=0

# 1 = install requirements/install.py for custom nodes when needed
CUSTOM_NODES_INSTALL_DEPS=1
