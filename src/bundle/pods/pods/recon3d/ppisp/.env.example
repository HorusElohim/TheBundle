# CUDA torch wheel index for pip install
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128

# Torch packages installed in the image
TORCH_PACKAGES=torch torchvision torchaudio

# editable (default) or wheel
PPISP_INSTALL_MODE=editable

# 1 = install local TheBundle source at startup (for bundle.core usage)
INSTALL_BUNDLE=1

# Optional, passed to PPISP build (examples: 8.6;8.9;9.0 or 8.9+PTX)
TORCH_CUDA_ARCH_LIST=
